{
    "private": true,
    "scripts": {
        "build": "npx @tailwindcss/cli -i resources/css/index.css -o resources/dist/web-terminal.css --minify",
        "build:js": "npx esbuild resources/js/ghostty-terminal.js --bundle --minify --format=iife --global-name=GhosttyWeb --outfile=resources/dist/ghostty-terminal.js",
        "build:all": "npm run build && npm run build:js"
    },
    "dependencies": {
        "ghostty-web": "^0.4.0"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.0",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.1.0"
    }
}
